# Configuración de Supabase
# Reemplaza estos valores con los de tu proyecto real
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Configuración de la app
VITE_APP_NAME="Sistema Scout Lima 12"
VITE_APP_VERSION="1.0.0"

# Configuración opcional
VITE_ENABLE_ANALYTICS=false
VITE_DEBUG_MODE=true

# URL pública de la aplicación (para auth callbacks)
# En producción (Azure): URL de tu app desplegada
# Si no se define, los magic links apuntarán a window.location.origin (localhost)
# VITE_APP_URL=https://tu-app.azurestaticapps.net

# ─── Solo para desarrollo local (.env.local, NO commitear) ─────────────
#
# MODO 1: Bypass de UI sin sesión real de Supabase
# Las mutaciones RPC son simuladas. Solo para desarrollo de UI puro.
# VITE_DEV_SKIP_AUTH=true
#
# MODO 2: Auto-login silencioso (RECOMENDADO)
# Crea sesión Supabase real → todas las RPC leen y graban de verdad.
# VITE_DEV_EMAIL=tu-correo@ejemplo.com
# VITE_DEV_PASSWORD=tu-contraseña-aqui